From 28206bf4b10ced80abdd8c67df2aef354341c01c Mon Sep 17 00:00:00 2001
From: Bob Feng <bob.c.feng@intel.com>
Date: Mon, 28 Dec 2020 16:34:43 +0800
Subject: [Patch] Test case for Add included .h changing - nasm file

Description: Add included ForHAddTest.h file in the Sec/Ia32/SecEntry.nasm

Repo: edk2

Signed-off-by: Bob Feng <bob.c.feng@intel.com>
---
 TestPkg/Sec/Ia32/SecEntry.nasm | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/TestPkg/Sec/Ia32/SecEntry.nasm b/TestPkg/Sec/Ia32/SecEntry.nasm
index 24b1c20ca8..ecdb1a80fa 100644
--- a/TestPkg/Sec/Ia32/SecEntry.nasm
+++ b/TestPkg/Sec/Ia32/SecEntry.nasm
@@ -8,10 +8,11 @@
 ;*   Abstract:
 ;*
 ;------------------------------------------------------------------------------
 
 #include <Base.h>
+#include "ForHAddTest.h"
 
     SECTION .text
 
 extern ASM_PFX(SecCoreStartupWithStack)
 
@@ -40,11 +41,11 @@ ASM_PFX(_ModuleEntryPoint):
     ;
     mov     eax, FixedPcdGet32 (PcdInitValueInTempStack)      ; dword to store
     mov     edi, FixedPcdGet32 (PcdOvmfSecPeiTempRamBase)     ; base address,
                                                               ;   relative to
                                                               ;   ES
-    mov     ecx, FixedPcdGet32 (PcdOvmfSecPeiTempRamSize) / 4 ; dword count
+    mov     ecx, FixedPcdGet32 (PcdOvmfSecPeiTempRamSize) / NumForTest ; dword count
     cld                                                       ; store from base
                                                               ;   up
     rep stosd
 
     ;
